<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>

<HBox fx:id="navbar" alignment="CENTER_RIGHT" prefHeight="68.0" prefWidth="1365.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.NavbarDosenController">

    <padding>
        <Insets left="20" right="20" />
    </padding>
    <children>
        <ImageView fitHeight="64.0" fitWidth="207.0">
            <image>
                <Image url="@../images/logo.png" />
            </image>
            <HBox.margin>
                <Insets right="710.0" />
            </HBox.margin>
        </ImageView>

        <Button fx:id="btnProfil" onAction="#goToProfil" style="-fx-background-color: transparent; -fx-font-size: 14;" text="Profil" />
        <Button fx:id="btnPesan" onAction="#goToPesan" style="-fx-background-color: transparent; -fx-font-size: 14;" text="Pesan" />
        <Button fx:id="btnMahasiswa" onAction="#goToMahasiswa" style="-fx-background-color: transparent; -fx-font-size: 14;" text="Mahasiswa" />
        <Button fx:id="btnPengaturan" onAction="#goToPengaturan" style="-fx-background-color: transparent; -fx-font-size: 14;" text="Pengaturan" />
    </children>
</HBox>
