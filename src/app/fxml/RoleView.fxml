<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="root" prefHeight="720.0" prefWidth="1340.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="app.controllers.RoleViewController">

    <!-- Background Image -->
    <ImageView fx:id="bgImage" preserveRatio="false" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <image>
         <Image url="@../images/bg-grey.png" />
      </image></ImageView>

    <!-- Content -->
    <VBox alignment="CENTER" spacing="25.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <Button onAction="#daftarMahasiswa" prefHeight="60" prefWidth="320" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Daftar sebagai Mahasiswa" />

        <Button onAction="#daftarDosen" prefHeight="60" prefWidth="320" style="-fx-font-size: 18px; -fx-font-weight: bold;" text="Daftar sebagai Dosen" />

    </VBox>
</AnchorPane>
